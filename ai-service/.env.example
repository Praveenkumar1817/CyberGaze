# CyberGaze AI Service — Environment Configuration Template
# Copy this file to .env and fill in your values

# ── Groq LLM (Llama 3 via Groq Cloud) ──────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Log data ────────────────────────────────────────
LOG_CSV_PATH=./forensic_logs.csv

# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
